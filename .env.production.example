# 生产环境配置模板
# 请复制此文件为 .env.production 并填入实际的生产环境配置值
# 注意：不要将 .env.production 文件提交到 git 仓库

# 数据库配置
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/intern_agent_prod

# 数据库连接池配置
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_MAX_OVERFLOW=20

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# API 认证密钥（生产环境请使用强密钥）
API_KEY=your-production-api-key-here

# GLM AI 配置
GLM_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4
GLM_TIMEOUT=30

# CORS 配置（生产环境请填入实际的前端域名）
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# 服务器配置
HOST=0.0.0.0
PORT=8000