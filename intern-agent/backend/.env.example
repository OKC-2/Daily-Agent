# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/intern_agent

# 数据库连接池配置
DB_POOL_SIZE=5
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_MAX_OVERFLOW=10

# API 认证
API_KEY=your-secret-api-key-here

# GLM API 配置
GLM_API_KEY=your-glm-api-key-here
GLM_MODEL=glm-4
GLM_TIMEOUT=30

# Redis 配置（可选，用于限流）
REDIS_URL=redis://localhost:6379

# CORS 配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志级别
LOG_LEVEL=INFO
