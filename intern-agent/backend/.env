# 数据库配置
# 请填写你的数据库连接字符串，例如: mysql+pymysql://用户名:密码@localhost:3306/数据库名
DATABASE_URL=

# 数据库连接池配置
DB_POOL_SIZE=5
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_MAX_OVERFLOW=10

# API 认证密钥
# 请填写一个随机生成的强密钥（建议至少32位）
API_KEY=

# GLM API 配置
# 请填写你的 GLM API 密钥
GLM_API_KEY=
GLM_MODEL=glm-4
GLM_TIMEOUT=30

# Redis 配置（可选，用于限流）
REDIS_URL=redis://localhost:6379

# CORS 配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志级别
LOG_LEVEL=INFO
